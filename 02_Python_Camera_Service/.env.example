# Python runtime
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=3037
LOG_LEVEL=INFO

# Storage mode: postgres | local
STORAGE_MODE=postgres
LOCAL_STORAGE_PATH=./.local_storage

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME
DB_DATABASE=astro_camera
DB_SSLMODE=prefer

# SDK mode: native | mock
SDK_MODE=native
SDK_DLL_PATH=
SDK_CAMERA_ADDRESS=
SDK_CAMERA_INTERFACE=-1
SDK_CAMERA_PORT=12345
SDK_READOUT_SPEED=1000
SDK_SENSOR_OUTPUT_MODE=0
SDK_BIT_DEPTH=2
SDK_BUSY_TIMEOUT_MS=3000
CAMERA_INDEX=0
CAMERA_HAS_SHUTTER=true
COOLING_HARDWARE_OPTION=42223

# FITS export: 16 (int16+BZERO 32768) or 32 (int32 ADU); переопределяется PUT /settings
FITS_EXPORT_BITPIX=32

# Optional S3 (for future use)
S3_ENDPOINT_URL=https://s3.example.com
S3_BUCKET=your-bucket-name
S3_PROJECT_PREFIX=your-project-prefix
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
